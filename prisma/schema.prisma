// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  fullName  String?  @map("full_name")
  phone     String?
  location  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile         UserProfile?
  jobMatches      JobMatch[]
  applications    Application[]
  documents       Document[]
  activityLogs    ActivityLog[]
  tailoredResumes TailoredResume[]

  @@map("users")
}

model UserProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique @map("user_id")
  baseResumeUrl      String?  @map("base_resume_url")
  skills             String[]
  experienceYears    Int?     @map("experience_years")
  jobTitles          String[] @map("job_titles")
  industries         String[]
  minSalary          Int?     @map("min_salary")
  maxSalary          Int?     @map("max_salary")
  preferredLocations String[] @map("preferred_locations")
  workType           String?  @map("work_type")
  status             String   @default("active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Job {
  id             Int       @id @default(autoincrement())
  externalId     String    @unique @map("external_id")
  source         String
  sourceUrl      String    @map("source_url")
  title          String
  companyName    String    @map("company_name")
  companyUrl     String?   @map("company_url")
  location       String?
  workType       String?   @map("work_type")
  employmentType String?   @map("employment_type")
  salaryMin      Int?      @map("salary_min")
  salaryMax      Int?      @map("salary_max")
  description    String?
  requirements   String?
  postedDate     DateTime? @map("posted_date")
  scrapedAt      DateTime  @default(now()) @map("scraped_at")
  status         String    @default("active")
  createdAt      DateTime  @default(now()) @map("created_at")

  jobMatches JobMatch[]

  @@index([companyName])
  @@index([postedDate])
  @@map("jobs")
}

model JobMatch {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  jobId         Int      @map("job_id")
  matchScore    Decimal  @map("match_score") @db.Decimal(5, 2)
  aiReasoning   String?  @map("ai_reasoning")
  skillsMatched String[] @map("skills_matched")
  skillsMissing String[] @map("skills_missing")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applications Application[]

  @@unique([userId, jobId])
  @@index([userId])
  @@index([matchScore])
  @@map("job_matches")
}

model Application {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  jobMatchId        Int       @map("job_match_id")
  status            String    @default("draft")
  appliedDate       DateTime? @map("applied_date")
  tailoredResumeUrl String?   @map("tailored_resume_url")
  coverLetterUrl    String?   @map("cover_letter_url")
  notes             String?
  rejectionDate     DateTime? @map("rejection_date")
  rejectionReason   String?   @map("rejection_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobMatch   JobMatch    @relation(fields: [jobMatchId], references: [id], onDelete: Cascade)
  interviews Interview[]
  followUps  FollowUp[]

  @@index([status])
  @@index([userId])
  @@map("applications")
}

model Interview {
  id               Int       @id @default(autoincrement())
  applicationId    Int       @map("application_id")
  interviewType    String?   @map("interview_type")
  scheduledDate    DateTime? @map("scheduled_date")
  durationMinutes  Int?      @map("duration_minutes")
  interviewerName  String?   @map("interviewer_name")
  interviewerTitle String?   @map("interviewer_title")
  location         String?
  status           String    @default("scheduled")
  prepNotesUrl     String?   @map("prep_notes_url")
  feedback         String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

model Document {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  documentType String   @map("document_type")
  jobMatchId   Int?     @map("job_match_id")
  fileUrl      String   @map("file_url")
  fileName     String?  @map("file_name")
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model CompanyResearch {
  id                 Int      @id @default(autoincrement())
  applicationId      Int?     @map("application_id")
  jobId              Int      @map("job_id")
  userId             Int      @map("user_id")
  companyName        String   @map("company_name")
  companyUrl         String?  @map("company_url")
  companyOverview    String?  @map("company_overview")
  missionAndValues   String?  @map("mission_and_values")
  recentDevelopments Json?    @map("recent_developments")
  whyTheyAreHiring   String?  @map("why_they_are_hiring")
  talkingPoints      Json?    @map("talking_points")
  questionsToAsk     Json?    @map("questions_to_ask")
  redFlags           Json?    @map("red_flags")
  researchNotes      String?  @map("research_notes")
  confidenceScore    Int?     @map("confidence_score")
  htmlContent        String?  @map("html_content")
  pdfBinary          Bytes?   @map("pdf_binary")
  websiteScraped     Boolean  @default(false) @map("website_scraped")
  newsCount          Int      @default(0) @map("news_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([jobId, userId])
  @@map("company_research")
}

model FollowUp {
  id            Int       @id @default(autoincrement())
  applicationId Int       @map("application_id")
  followUpType  String    @map("follow_up_type")
  scheduledDate DateTime  @map("scheduled_date")
  sentDate      DateTime? @map("sent_date")
  emailTemplate String?   @map("email_template")
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([scheduledDate])
  @@map("follow_ups")
}

model ActivityLog {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  activityType String   @map("activity_type")
  entityType   String?  @map("entity_type")
  entityId     Int?     @map("entity_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model TailoredResume {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  jobId               Int      @map("job_id")
  resumeUrl           String   @map("resume_url")
  storagePath         String   @map("storage_path")
  pdfFilename         String   @map("pdf_filename")
  professionalSummary String?  @map("professional_summary")
  tailoringNotes      String?  @map("tailoring_notes")
  version             Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tailored_resumes")
}
